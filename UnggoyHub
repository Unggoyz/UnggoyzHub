--ESP--
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

local ESPEnabled = false

local ESPObjects = {}
local NameObjects = {}
local Connections = {}

local function createHighlight(char)
    if char:FindFirstChild("ESP_Highlight") then
        char.ESP_Highlight:Destroy()
    end

    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = char
    highlight.FillColor = Color3.fromRGB(255, 60, 60)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.4
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = char

    return highlight
end

local function createNameESP(player, character)
    local head = character:FindFirstChild("Head")
    if not head then return end

    if NameObjects[player] then
        NameObjects[player]:Destroy()
    end

    local billboard = Instance.new("BillboardGui")
    billboard.Name = "NameESP"
    billboard.Size = UDim2.new(0, 120, 0, 30)
    billboard.StudsOffset = Vector3.new(0, 2.5, 0)
    billboard.AlwaysOnTop = true
    billboard.Adornee = head
    billboard.Parent = head

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextStrokeTransparency = 0
    label.TextScaled = true
    label.Font = Enum.Font.SourceSansBold
    label.Text = player.DisplayName .. " (@" .. player.Name .. ")"
    label.Parent = billboard

    NameObjects[player] = billboard
end

local function isValid(player)
    return player ~= LocalPlayer
end

local function applyESP(player)
    if not isValid(player) then return end

    local function onCharacter(char)
        if not ESPEnabled then return end

        ESPObjects[player] = createHighlight(char)
        createNameESP(player, char)
    end

    if player.Character then
        onCharacter(player.Character)
    end

    if Connections[player] then
        Connections[player]:Disconnect()
    end

    Connections[player] = player.CharacterAdded:Connect(onCharacter)
end

local function enableESP()
    if ESPEnabled then return end
    ESPEnabled = true

    for _, player in ipairs(Players:GetPlayers()) do
        applyESP(player)
    end

    Connections._join = Players.PlayerAdded:Connect(function(player)
        if ESPEnabled then
            applyESP(player)
        end
    end)
end

local function disableESP()
    ESPEnabled = false

    for _, highlight in pairs(ESPObjects) do
        if highlight then highlight:Destroy() end
    end
    table.clear(ESPObjects)

    for _, nameGui in pairs(NameObjects) do
        if nameGui then nameGui:Destroy() end
    end
    table.clear(NameObjects)

    for _, conn in pairs(Connections) do
        if conn then conn:Disconnect() end
    end
    table.clear(Connections)
end

local function toggleESP()
    if ESPEnabled then
        disableESP()
    else
        enableESP()
    end
end
